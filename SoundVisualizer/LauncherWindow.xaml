<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="SoundVisualizer.LauncherWindow"
        Title="SoundVisualizer Launcher" Height="650" Width="800"
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown" FontFamily="Malgun Gothic, Segoe UI">

    <Window.Resources>
        <!-- Toss Colors -->
        <SolidColorBrush x:Key="BgColor" Color="#2A2C31"/>
        <SolidColorBrush x:Key="CardColor" Color="#1E2024"/>
        <SolidColorBrush x:Key="PrimaryTextColor" Color="#F2F4F6"/>
        <SolidColorBrush x:Key="SecondaryTextColor" Color="#8B95A1"/>
        <SolidColorBrush x:Key="AccentColor" Color="#3182F6"/>
        <SolidColorBrush x:Key="AccentHoverColor" Color="#1B64DA"/>
        <SolidColorBrush x:Key="DividerColor" Color="#222429"/>

        <!-- Primary Button -->
        <Style x:Key="TossButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,16"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentHoverColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#104EAD"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Background" Value="#333A44"/>
                                <Setter Property="Foreground" Value="#8B95A1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TossDangerButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#E53935"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,16"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#EF5350"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#C62828"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Background" Value="#333A44"/>
                                <Setter Property="Foreground" Value="#8B95A1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TossSecondaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource TossButton}">
            <Setter Property="Background" Value="#333A44"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextColor}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#454D59"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Card Style -->
        <Style x:Key="TossCard" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource CardColor}"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <!-- Minimalist TabControl -->
        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextColor}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Grid Background="Transparent" Margin="0,0,24,0">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="0,0,0,12"/>
                            <Border x:Name="Indicator" Height="3" Background="Transparent" VerticalAlignment="Bottom" CornerRadius="1.5"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextColor}"/>
                                <Setter TargetName="Indicator" Property="Background" Value="{StaticResource PrimaryTextColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toss Slider -->
        <Style x:Key="TossSlider" TargetType="{x:Type Slider}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid VerticalAlignment="Center">
                            <Border Height="8" Background="#333A44" CornerRadius="4" VerticalAlignment="Center" Margin="10,0"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                <Border Height="8" Background="{StaticResource AccentColor}" CornerRadius="4,0,0,4"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                <Border Height="8" Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Ellipse Width="24" Height="24" Fill="White">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="2" Opacity="0.3"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toss CheckBox -->
        <Style x:Key="TossCheckBox" TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextColor}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="26" Height="26" VerticalAlignment="Center">
                                <Border x:Name="CheckBg" Background="#333A44" CornerRadius="8" BorderThickness="0"/>
                                <Path x:Name="CheckMark" Data="M 7 13 L 11 17 L 19 9" Stroke="White" StrokeThickness="3.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Visibility="Collapsed"/>
                            </Grid>
                            <ContentPresenter VerticalAlignment="Center" Margin="14,0,0,0"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBg" Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toss CheckBox (Right) -->
        <Style x:Key="TossCheckBoxRight" TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextColor}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <StackPanel Orientation="Horizontal">
                            <ContentPresenter VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <Grid Width="26" Height="26" VerticalAlignment="Center">
                                <Border x:Name="CheckBg" Background="#333A44" CornerRadius="8" BorderThickness="0"/>
                                <Path x:Name="CheckMark" Data="M 7 13 L 11 17 L 19 9" Stroke="White" StrokeThickness="3.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Visibility="Collapsed"/>
                            </Grid>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBg" Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toss ComboBox -->
        <Style x:Key="TossComboBox" TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="#F2F4F6"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Grid.Column="2" Focusable="false" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource Mode=TemplatedParent}}" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="Bg" CornerRadius="10" Background="{TemplateBinding Background}">
                                            <Path x:Name="Arrow" Fill="#111111" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0" Data="M0,0 L10,0 L5,6 Z"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" HorizontalAlignment="Left" TextElement.Foreground="{TemplateBinding Foreground}"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder" Background="#FFFFFF" BorderThickness="1" BorderBrush="#E5E8EB" CornerRadius="10" Margin="0,6,0,0" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="4" Opacity="0.1"/>
                                    </Border.Effect>
                                    <ScrollViewer Margin="6,8" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="8" Margin="0,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F2F4F6"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#E5E8EB"/>
                                <Setter Property="Foreground" Value="#3182F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toss Expander Style -->
        <Style x:Key="TossExpander" TargetType="{x:Type Expander}">
            <Setter Property="Background" Value="{StaticResource CardColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Expander}">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20" Padding="24" BorderBrush="#222429" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition x:Name="ContentRow" Height="0"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Header Button -->
                                <ToggleButton x:Name="HeaderButton" Grid.Row="0" IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Content="{TemplateBinding Header}" Cursor="Hand" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                                            <Grid Background="Transparent">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Header Content -->
                                                <ContentPresenter Grid.Column="0" ContentSource="Content" RecognizesAccessKey="True" VerticalAlignment="Center"/>
                                                <!-- Arrow Indicator -->
                                                <Path x:Name="Arrow" Grid.Column="1" Fill="{StaticResource SecondaryTextColor}" HorizontalAlignment="Right" VerticalAlignment="Center" Data="M 0,0 L 5,5 L 10,0 Z" RenderTransformOrigin="0.5,0.5" Margin="0,0,8,0">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="0"/>
                                                    </Path.RenderTransform>
                                                </Path>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Arrow" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="180"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <!-- Expandable Content -->
                                <Border x:Name="ContentBorder" Grid.Row="1" Visibility="Collapsed" Margin="0,16,0,0">
                                    <ContentPresenter/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ContentRow" Property="Height" Value="*"/>
                                <Setter TargetName="ContentBorder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Window Background -->
    <Border CornerRadius="24" Background="{StaticResource BgColor}" BorderBrush="#1C1D22" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Top Bar -->
            <Grid Grid.Row="0" Margin="24,24,24,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtLanguageLabel" Text="Language" Foreground="{StaticResource SecondaryTextColor}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="CmbLanguage" Style="{StaticResource TossComboBox}" Width="120" Padding="12,8" FontSize="14" SelectionChanged="CmbLanguage_SelectionChanged">
                        <ComboBoxItem Content="한국어" IsSelected="True"/>
                        <ComboBoxItem Content="English"/>
                        <ComboBoxItem Content="日本語"/>
                        <ComboBoxItem Content="中文"/>
                        <ComboBoxItem Content="Español"/>
                        <ComboBoxItem Content="Français"/>
                        <ComboBoxItem Content="Deutsch"/>
                        <ComboBoxItem Content="Русский"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-24,-24,0">
                    <Button Content="&#xE921;" FontFamily="Segoe MDL2 Assets" Width="46" Height="32" 
                            FontSize="10" Foreground="{StaticResource SecondaryTextColor}" Background="Transparent" BorderThickness="0" Click="BtnMinimize_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border x:Name="MinBg" Background="Transparent" CornerRadius="0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="MinBg" Property="Background" Value="#3D3F45"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" Width="46" Height="32" 
                            FontSize="10" Foreground="{StaticResource SecondaryTextColor}" Background="Transparent" BorderThickness="0" Click="BtnClose_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border x:Name="CloseBg" Background="Transparent" CornerRadius="0,24,0,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CloseBg" Property="Background" Value="#E81123"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Tab Control -->
            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="24,24,24,0">

                <!-- 홈 (실행) 탭 -->
                <TabItem x:Name="TabHome" Header="홈">
                    <Grid>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="20,0">
                            <TextBlock x:Name="TxtHomeTitle" Text="SoundVisualizer" FontSize="36" FontWeight="Black" Foreground="{StaticResource PrimaryTextColor}" Margin="0,0,0,12"/>
                            <TextBlock x:Name="TxtHomeDesc" Text="보이지 않던 소리를 화면에 그려냅니다.&#xA;게이밍부터 영화 감상까지 새로운 경험을 시작하세요." 
                                       FontSize="16" Foreground="{StaticResource SecondaryTextColor}" LineHeight="26" Margin="0,0,0,24"/>



                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <Ellipse x:Name="StatusDot" Width="12" Height="12" Fill="#8B95A1" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtStatus" Text="상태: 실행 대기 중" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextColor}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" x:Name="BtnLaunch" Content="실행" Style="{StaticResource TossButton}" Click="BtnLaunch_Click"/>
                                <Button Grid.Column="2" x:Name="BtnStop" Content="실행 중단" Style="{StaticResource TossDangerButton}" Click="BtnStop_Click" IsEnabled="False"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- 설정 탭 -->
                <TabItem x:Name="TabSettings" Header="설정">
                    <ScrollViewer VerticalScrollBarVisibility="Hidden" Margin="0,16,0,0">
                        <StackPanel Margin="0,0,0,24">

                            <TextBlock x:Name="TxtModeSettings" Text="모드 설정" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryTextColor}" Margin="0,0,0,16"/>

                            <Border Style="{StaticResource TossCard}" Margin="0,0,0,24">
                                <StackPanel>
                                    <StackPanel Margin="0,0,0,24">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock x:Name="TxtVisualModeLabel" Text="표현 모드" FontSize="16" Foreground="{StaticResource PrimaryTextColor}" FontWeight="Bold" Margin="0,0,0,8"/>
                                                <TextBlock x:Name="TxtVisualModeDesc" Text="화면에 그려질 그래픽의 기본 형태를 선택합니다." FontSize="13" Foreground="{StaticResource SecondaryTextColor}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <ComboBox Grid.Column="1" x:Name="CmbVisualMode" Style="{StaticResource TossComboBox}" HorizontalAlignment="Right" MinWidth="160" VerticalAlignment="Center" SelectionChanged="Setting_Changed">
                                                <ComboBoxItem x:Name="CmbVisualModeWave" Content="파도"/>
                                                <ComboBoxItem x:Name="CmbVisualModePad" Content="패드"/>
                                                <ComboBoxItem x:Name="CmbVisualModeCircle" Content="원형"/>
                                                <ComboBoxItem x:Name="CmbVisualModeOutline" Content="외각선"/>
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock x:Name="TxtSoundModeLabel" Text="사운드 모드" FontSize="16" Foreground="{StaticResource PrimaryTextColor}" FontWeight="Bold" Margin="0,0,0,8"/>
                                                <TextBlock x:Name="TxtSoundModeDesc" Text="스피커 환경에 맞는 사운드 채널을 선택합니다.&#x0a;2채널 환경은 '2 채널', 서라운드 환경은 '5.1 채널' 또는 '7.1 채널'을 선택하세요." FontSize="13" Foreground="{StaticResource SecondaryTextColor}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <ComboBox Grid.Column="1" x:Name="CmbSoundMode" Style="{StaticResource TossComboBox}" HorizontalAlignment="Right" MinWidth="160" VerticalAlignment="Center" SelectionChanged="Setting_Changed">
                                                <ComboBoxItem x:Name="CmbSoundMode2" Content="2 채널"/>
                                                <ComboBoxItem x:Name="CmbSoundMode51" Content="5.1 채널"/>
                                                <ComboBoxItem x:Name="CmbSoundMode71" Content="7.1 채널"/>
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock x:Name="TxtModeDetailSettings" Text="모드별 상세 설정" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryTextColor}" Margin="0,0,0,16"/>

                            <!-- 모드 상세 설정 아코디언들을 묶는 전용 컨테이너 (동적 정렬 대상) -->
                            <StackPanel x:Name="PanelModeExpanders">
                                <!-- 🌊 파도 모드 설정 -->
                            <Expander x:Name="ExpanderWave" Style="{StaticResource TossExpander}">
                                <Expander.Header>
                                    <TextBlock x:Name="TxtExpanderWaveTitle" Text="파도 모드 설정" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryTextColor}"/>
                                </Expander.Header>
                                <StackPanel>
                                    <StackPanel Margin="0,0,0,24">
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="170"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="TxtIntensityLabelWave" Text="크기" FontSize="16" Foreground="{StaticResource PrimaryTextColor}" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <Slider Grid.Column="1" x:Name="SldIntensityWave" Style="{StaticResource TossSlider}" Minimum="0" Maximum="100" Value="50" VerticalAlignment="Center" ValueChanged="Setting_Changed"/>
