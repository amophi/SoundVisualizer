<Window x:Class="SoundVisualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WaveSight 7.1" Height="1080" Width="1920"
        WindowStyle="None" Background="Transparent" AllowsTransparency="True"
        Topmost="True" WindowState="Maximized" ShowInTaskbar="False">
    
    <Grid x:Name="MainGrid">
        <!-- 시스템 상태 메시지 (상단 고정) -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,50,0,0" 
                Background="#60000000" CornerRadius="5" Padding="10,5" IsHitTestVisible="False">
            <TextBlock x:Name="StatusText" Foreground="White" FontSize="14" FontWeight="SemiBold" Text="시스템 준비 완료"/>
        </Border>

        <!-- 7.1 방향별 파도 (화면 전체 고정 앵커링) -->
        <Path x:Name="WaveFC" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False" Opacity="0.5"/>
        <Path x:Name="WaveLFE" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False" Opacity="0.5"/>
        <Path x:Name="WaveSL" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False" Opacity="0.5"/>
        <Path x:Name="WaveSR" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False" Opacity="0.5"/>
        
        <Path x:Name="WaveFL" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False" Opacity="0.6"/>
        <Path x:Name="WaveFR" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False" Opacity="0.6"/>
        <Path x:Name="WaveBL" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False" Opacity="0.6"/>
        <Path x:Name="WaveBR" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False" Opacity="0.6"/>

        <!-- AI 라벨 (화면 정중앙) -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center" 
                Background="#90000000" CornerRadius="15" Padding="20" IsHitTestVisible="False">
            <TextBlock x:Name="AILabelText" Foreground="White" FontSize="26" 
                       FontWeight="Bold" Text="WaveSight 7.1 대기 중..."/>
        </Border>
    </Grid>
</Window>