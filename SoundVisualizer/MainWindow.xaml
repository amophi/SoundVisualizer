<Window x:Class="SoundVisualizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SoundVisualizer" Height="1080" Width="1920"
        WindowStyle="None" Background="Transparent" AllowsTransparency="True"
        Topmost="True" WindowState="Maximized" ShowInTaskbar="False">
    
    <Grid x:Name="MainGrid">
        <!-- 시스템 상태 메시지 (상단 고정) -->
        <Border x:Name="StatusBorder" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,50,0,0" 
                Background="#60000000" CornerRadius="5" Padding="10,5" IsHitTestVisible="False">
            <TextBlock x:Name="StatusText" Foreground="White" FontSize="14" FontWeight="SemiBold" Text="시스템 준비 완료"/>
        </Border>

        <!-- 통합 파도 (하나의 연속적인 둘레 웨이브) -->
        <Path x:Name="UnifiedWave" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False" Opacity="0.6">
            <Path.Effect>
                <DropShadowEffect x:Name="WaveGlowEffect" Color="White" BlurRadius="25" ShadowDepth="0" Opacity="0"/>
            </Path.Effect>
        </Path>

        <!-- AI 라벨 (화면 정중앙) -->
        <Border x:Name="AILabelBorder" HorizontalAlignment="Center" VerticalAlignment="Center" 
                Background="#90000000" CornerRadius="15" Padding="20" IsHitTestVisible="False">
            <TextBlock x:Name="AILabelText" Foreground="White" FontSize="26" 
                       FontWeight="Bold" Text="SoundVisualizer 대기 중..."/>
        </Border>

        <!-- FPS 카운터 (디버그용, 우상단) -->
        <Border x:Name="FpsBorder" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,50,20,0" 
                Background="#60000000" CornerRadius="5" Padding="8,4" IsHitTestVisible="False">
            <TextBlock x:Name="FpsText" Foreground="#80FFFFFF" FontSize="11" Text="FPS: --"/>
        </Border>

        <!-- 모드 설정 UI (우하단) -->
        <StackPanel x:Name="ModeUIStack" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,20,20" IsHitTestVisible="False">
            <Border Background="#80000000" CornerRadius="5" Padding="12,8" Margin="0,0,0,8">
                <TextBlock x:Name="VisualModeText" Foreground="White" FontSize="16" FontWeight="SemiBold" Text="🎨 시각화 모드: [F3] 패드 모드 (Pad)"/>
            </Border>
            <Border Background="#80000000" CornerRadius="5" Padding="12,8">
                <TextBlock x:Name="StereoModeText" Foreground="White" FontSize="16" FontWeight="SemiBold" Text="🔊 채널 확장 모드: [F2] 7.1 서라운드"/>
            </Border>
        </StackPanel>
    </Grid>
</Window>